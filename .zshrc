# Autosuggestions
source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh

# --- Dotfiles ---
alias dotfiles='git --git-dir=$HOME/.dotfiles/ --work-tree=$HOME'
alias dlg='lazygit --git-dir=$HOME/.dotfiles/ --work-tree=$HOME'

# --- Personal aliases ---
source ~/.zsh_aliases

# --- Prompt and tools ---
#eval "$(starship init zsh)"

 fpath+=(/opt/homebrew/share/zsh/site-functions)
 autoload -U promptinit; promptinit

 zstyle :prompt:pure:path color '#d79921'
 zstyle :prompt:pure:git:branch color '#689d6a'
 zstyle :prompt:pure:git:dirty color '#d65d0e'
 zstyle :prompt:pure:git:action color '#d65d0e'
 zstyle :prompt:pure:git:arrow color '#fbf1c7'
 zstyle :prompt:pure:prompt:success color '#98971a'
 zstyle :prompt:pure:prompt:error color '#cc241d'
 zstyle :prompt:pure:user color '#d79921'
 zstyle :prompt:pure:host color '#458588'
 zstyle :prompt:pure:execution_time color '#d65d0e'

 prompt pure

eval "$(zoxide init zsh)"
